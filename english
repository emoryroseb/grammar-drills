<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammar Drills</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --ink: #1a1208; --paper: #f5f0e8; --cream: #ede7d4; --rule: #c8bfa8;
  --red: #b83232; --green: #2a6e3f; --gold: #c4993a; --blue: #2b4c8c;
  --blue-light: rgba(43,76,140,0.10);
}
body {
  background: var(--paper); color: var(--ink);
  font-family: 'Source Serif 4', Georgia, serif; min-height: 100vh;
  background-image: repeating-linear-gradient(0deg, transparent, transparent 27px, var(--rule) 27px, var(--rule) 28px);
  background-attachment: fixed;
}
header {
  background: var(--ink); color: var(--paper); padding: 15px 28px;
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 200; box-shadow: 0 2px 14px rgba(0,0,0,0.4);
}
.logo { font-family: 'Source Serif 4', serif; font-size: 1.35rem; letter-spacing: .1em; text-transform: uppercase; font-weight: 300; }
.logo span { color: var(--gold); font-weight: 600; }
.mode-toggle { display: flex; }
.mode-btn {
  font-family: 'Source Serif 4', serif; font-size: 0.76rem; text-transform: uppercase;
  letter-spacing: .1em; padding: 7px 18px; cursor: pointer;
  border: 1.5px solid rgba(255,255,255,0.22); background: transparent;
  color: rgba(255,255,255,0.55); transition: all .15s;
}
.mode-btn:first-child { border-radius: 2px 0 0 2px; }
.mode-btn:last-child  { border-radius: 0 2px 2px 0; border-left: none; }
.mode-btn.active { background: var(--gold); color: var(--ink); border-color: var(--gold); font-weight: 600; }
main { max-width: 820px; margin: 0 auto; padding: 34px 20px 90px; }

/* ─── shared components ─── */
.btn-primary { font-family:'Playfair Display',serif; font-size:.93rem; padding:10px 26px; background:var(--ink); color:var(--paper); border:none; cursor:pointer; border-radius:2px; letter-spacing:.05em; transition:background .15s; }
.btn-primary:hover { background:#2e2515; }
.btn-secondary { font-family:'Playfair Display',serif; font-size:.93rem; padding:10px 20px; background:transparent; color:var(--ink); border:1.5px solid var(--rule); cursor:pointer; border-radius:2px; transition:border-color .15s; }
.btn-secondary:hover { border-color:var(--ink); }
.btn-ghost { font-family:'Source Serif 4',serif; font-size:.78rem; text-transform:uppercase; letter-spacing:.08em; padding:6px 14px; background:transparent; color:var(--gold); border:1.5px solid var(--gold); cursor:pointer; border-radius:2px; transition:all .12s; }
.btn-ghost:hover { background:var(--gold); color:var(--ink); }
.btn-danger { font-family:'Source Serif 4',serif; font-size:.78rem; padding:5px 10px; background:transparent; color:#a05050; border:1px solid #d4a0a0; cursor:pointer; border-radius:2px; transition:all .12s; }
.btn-danger:hover { background:#faeaea; border-color:var(--red); color:var(--red); }
.section-title { font-family:'Playfair Display',serif; font-size:1.5rem; font-style:italic; margin-bottom:5px; }
.section-sub { font-size:.87rem; color:#7a6a50; margin-bottom:26px; line-height:1.6; }
.hint { font-size:.77rem; color:#9a8a70; font-style:italic; margin-top:4px; }
label.field-label { display:block; font-size:.73rem; text-transform:uppercase; letter-spacing:.09em; color:#7a6a50; margin-bottom:5px; }
textarea, input[type=text], select {
  width:100%; font-family:'Source Serif 4',serif; font-size:.94rem;
  padding:9px 12px; border:1.5px solid var(--rule); background:var(--paper);
  color:var(--ink); border-radius:2px; line-height:1.55; transition:border-color .12s;
}
textarea:focus, input[type=text]:focus, select:focus { outline:none; border-color:var(--ink); }
textarea { resize:vertical; }
.toast {
  position:fixed; bottom:26px; left:50%; transform:translateX(-50%) translateY(80px);
  background:var(--ink); color:var(--paper); padding:11px 22px; border-radius:2px;
  font-size:.87rem; z-index:999; transition:transform .3s; pointer-events:none;
  box-shadow:0 4px 16px rgba(0,0,0,.3);
}
.toast.show { transform:translateX(-50%) translateY(0); }

/* ══════════════════════════════════════
   TUTOR MODE
══════════════════════════════════════ */
#tutor-mode { display:block; }
#student-mode { display:none; }

/* passage card in bank */
.passage-card {
  background:#faf6ed; border:1px solid var(--rule); border-left:4px solid var(--ink);
  margin-bottom:16px; border-radius:1px; overflow:hidden;
}
.passage-card-header {
  display:flex; align-items:flex-start; gap:12px; padding:15px 18px;
  cursor:pointer; user-select:none;
}
.passage-card-header:hover { background:#f3ece0; }
.pch-body { flex:1; min-width:0; }
.pch-title { font-family:'Playfair Display',serif; font-size:1rem; font-style:italic; }
.pch-meta { font-size:.76rem; color:#9a8a70; margin-top:3px; }
.pch-chevron { font-size:.8rem; color:#9a8a70; padding-top:3px; transition:transform .2s; }
.pch-chevron.open { transform:rotate(90deg); }
.passage-card-body { border-top:1px solid var(--rule); padding:16px 18px; display:none; }
.passage-card-body.open { display:block; }
.passage-preview {
  background:var(--cream); border-left:3px solid var(--rule);
  padding:12px 15px; font-size:.88rem; line-height:1.75; font-style:italic;
  color:#3a2e18; margin-bottom:14px; max-height:120px; overflow:hidden;
  position:relative;
}
.passage-preview::after { content:''; position:absolute; bottom:0; left:0; right:0; height:30px; background:linear-gradient(transparent, var(--cream)); }
.questions-list { display:flex; flex-direction:column; gap:8px; margin-bottom:14px; }
.q-row {
  display:flex; align-items:center; gap:10px; padding:10px 13px;
  background:var(--paper); border:1px solid var(--rule); border-radius:2px;
}
.q-row-body { flex:1; min-width:0; }
.q-row-stem { font-size:.88rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.q-row-meta { font-size:.73rem; color:#9a8a70; margin-top:2px; }
.q-row-actions { display:flex; gap:5px; flex-shrink:0; }
.icon-btn { background:transparent; border:1px solid var(--rule); padding:4px 9px; cursor:pointer; font-size:.78rem; color:#7a6a50; border-radius:2px; transition:all .12s; }
.icon-btn:hover { border-color:var(--ink); color:var(--ink); }
.icon-btn.del:hover { border-color:var(--red); color:var(--red); }
.passage-card-footer { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }

/* standalone bank */
.standalone-section { margin-bottom:28px; }
.standalone-section h4 { font-family:'Playfair Display',serif; font-size:1rem; font-style:italic; color:#6b5e48; margin-bottom:10px; padding-bottom:6px; border-bottom:1px solid var(--rule); }
.empty-bank { text-align:center; padding:32px; border:2px dashed var(--rule); color:#a89878; font-style:italic; font-size:.9rem; border-radius:2px; margin-bottom:18px; }
.bank-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; flex-wrap:wrap; gap:10px; }
.bank-count { font-size:.8rem; color:#8a7a60; letter-spacing:.06em; text-transform:uppercase; }
.add-btns { display:flex; gap:8px; }

/* forms */
.form-card { background:#faf6ed; border:1px solid var(--rule); border-top:4px solid var(--gold); padding:28px 30px; box-shadow:3px 3px 0 var(--rule); margin-bottom:22px; }
.form-card h3 { font-family:'Playfair Display',serif; font-size:1.1rem; font-style:italic; margin-bottom:20px; }
.form-fields { display:flex; flex-direction:column; gap:16px; }
.field { display:flex; flex-direction:column; }
.field-2col { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.choices-block { display:flex; flex-direction:column; gap:8px; }
.choice-row { display:flex; align-items:center; gap:9px; }
.choice-ltr { font-family:'Playfair Display',serif; font-weight:700; font-size:.9rem; color:#8a7a60; min-width:20px; text-align:center; }
.choice-row input { flex:1; }
.correct-row { display:flex; gap:7px; flex-wrap:wrap; }
.correct-btn { font-family:'Playfair Display',serif; font-weight:700; padding:5px 13px; border:1.5px solid var(--rule); background:var(--paper); cursor:pointer; border-radius:2px; font-size:.88rem; color:#8a7a60; transition:all .12s; }
.correct-btn.sel { background:var(--green); border-color:var(--green); color:#fff; }
.btn-row { display:flex; gap:10px; margin-top:18px; flex-wrap:wrap; }
.divider { border:none; border-top:1px solid var(--rule); margin:26px 0; }

/* ══════════════════════════════════════
   STUDENT MODE
══════════════════════════════════════ */
.progress-wrap { height:4px; background:var(--rule); margin-bottom:22px; border-radius:2px; overflow:hidden; }
.progress-bar  { height:100%; background:var(--ink); transition:width .4s ease; }
.s-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; flex-wrap:wrap; gap:10px; }
.score-pill { font-size:.82rem; color:#6b5e48; }
.score-pill strong { font-family:'Playfair Display',serif; font-size:1rem; color:var(--ink); }
.cat-filter { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:20px; }
.cf-btn { font-size:.72rem; text-transform:uppercase; letter-spacing:.08em; padding:5px 11px; border:1.5px solid var(--rule); background:transparent; color:#7a6a60; cursor:pointer; border-radius:2px; transition:all .12s; }
.cf-btn:hover { border-color:var(--ink); color:var(--ink); }
.cf-btn.active { background:var(--ink); color:var(--paper); border-color:var(--ink); }

/* drill card */
.drill-card { background:#faf6ed; border:1px solid var(--rule); border-top:4px solid var(--ink); padding:28px 32px; box-shadow:3px 3px 0 var(--rule); margin-bottom:18px; }
.drill-meta { display:flex; align-items:center; gap:9px; margin-bottom:16px; flex-wrap:wrap; }
.badge { font-size:.66rem; text-transform:uppercase; letter-spacing:.1em; padding:3px 8px; border-radius:1px; }
.badge-passage { background:#dce8f5; color:#1a3560; border:1px solid #b0c8e8; }
.badge-sentence { background:#e8f0dc; color:#2a4010; border:1px solid #b8d098; }
.badge-cat { background:var(--cream); color:#5a4e38; border:1px solid var(--rule); }
.q-counter { margin-left:auto; font-family:'Playfair Display',serif; font-style:italic; color:#a89878; font-size:.84rem; }

.passage-display {
  border-left:3px solid var(--rule); padding:14px 17px;
  margin-bottom:18px; background:var(--cream); font-size:.97rem;
  line-height:1.9; font-style:italic; color:#2c2416;
}
.tested-phrase {
  text-decoration:underline; text-decoration-color:var(--blue);
  text-decoration-thickness:2px; text-underline-offset:3px;
  font-style:normal; color:var(--blue); background:var(--blue-light);
  padding:0 2px; border-radius:2px;
}
.q-stem { font-size:1rem; line-height:1.65; margin-bottom:18px; }
.choices-list { display:flex; flex-direction:column; gap:8px; }
.choice-opt {
  display:flex; align-items:flex-start; gap:12px; padding:11px 14px;
  background:var(--paper); border:1.5px solid var(--rule); text-align:left;
  cursor:pointer; border-radius:2px; font-family:'Source Serif 4',serif;
  font-size:.95rem; line-height:1.5; color:var(--ink);
  transition:border-color .12s, background .12s; width:100%;
}
.choice-opt:hover:not(:disabled) { border-color:var(--ink); background:var(--cream); }
.choice-opt:disabled { cursor:default; }
.opt-ltr { font-family:'Playfair Display',serif; font-weight:700; font-size:.87rem; color:#8a7a60; min-width:19px; padding-top:1px; }
.choice-opt.correct { border-color:var(--green); background:#eaf5ee; }
.choice-opt.correct .opt-ltr { color:var(--green); }
.choice-opt.wrong   { border-color:var(--red);   background:#faeaea; }
.choice-opt.wrong   .opt-ltr { color:var(--red); }
.expl-box { margin-top:14px; padding:13px 17px; border-left:3px solid var(--gold); background:#fdf8ec; font-size:.9rem; line-height:1.72; color:#3a2e18; display:none; }
.expl-box.show { display:block; }
.next-q-btn { margin-top:18px; display:none; font-family:'Playfair Display',serif; font-size:.93rem; padding:10px 28px; background:var(--ink); color:var(--paper); border:none; cursor:pointer; border-radius:2px; letter-spacing:.05em; transition:background .15s; }
.next-q-btn:hover { background:#2e2515; }
.next-q-btn.show { display:inline-block; }

/* passage progress bar (within a passage set) */
.passage-progress { font-size:.76rem; color:#9a8a70; margin-bottom:14px; letter-spacing:.04em; }

/* results */
#results-screen { display:none; text-align:center; padding:48px 20px; }
#results-screen h2 { font-family:'Playfair Display',serif; font-size:1.9rem; font-style:italic; margin-bottom:6px; }
.final-score { font-family:'Playfair Display',serif; font-size:3.8rem; color:var(--gold); line-height:1; margin:16px 0; }
.breakdown { max-width:430px; margin:22px auto; border:1px solid var(--rule); background:var(--cream); }
.bd-row { display:flex; justify-content:space-between; align-items:center; padding:9px 15px; border-bottom:1px solid var(--rule); font-size:.89rem; }
.bd-row:last-child { border-bottom:none; }
.bd-pct { font-family:'Playfair Display',serif; font-weight:700; }
.good { color:var(--green); } .ok { color:var(--gold); } .bad { color:var(--red); }
.no-q { text-align:center; padding:56px 20px; border:2px dashed var(--rule); color:#a89878; font-style:italic; }
.no-q p { margin-bottom:10px; }
</style>
</head>
<body>

<header>
  <div class="logo">Grammar <span>Drills</span></div>
  <div class="mode-toggle">
    <button class="mode-btn active" id="btn-tutor" onclick="switchMode('tutor')">✏️ Tutor</button>
    <button class="mode-btn" id="btn-student" onclick="switchMode('student')">📖 Student</button>
  </div>
</header>

<main>

<!-- ══ TUTOR ══ -->
<div id="tutor-mode">
  <div class="section-title">Question Bank</div>
  <p class="section-sub">Add passages (with multiple questions each) or standalone sentences. Students see each passage once with the tested phrase highlighted, working through all its questions together.</p>

  <div class="bank-top">
    <span class="bank-count" id="bank-count">0 items</span>
    <div class="add-btns">
      <button class="btn-ghost" onclick="openPassageForm()">+ New Passage</button>
      <button class="btn-ghost" onclick="openStandaloneForm()">+ Sentence Question</button>
      <button class="btn-ghost" onclick="exportBank()">⬇ Export</button>
      <label class="btn-ghost" style="cursor:pointer;">⬆ Import<input type="file" accept=".json" onchange="importBank(event)" style="display:none;"></label>
    </div>
  </div>

  <!-- Passage bank -->
  <div id="passage-bank"></div>

  <!-- Standalone bank -->
  <div class="standalone-section" id="standalone-section" style="display:none;">
    <h4>Standalone Sentence Questions</h4>
    <div id="standalone-bank"></div>
  </div>

  <hr class="divider">

  <!-- ── Passage form ── -->
  <div class="form-card" id="passage-form" style="display:none;">
    <h3 id="pf-title">New Passage</h3>
    <div class="form-fields">
      <div class="field">
        <label class="field-label">Passage Title <span style="color:#9a8a70;">(for your reference)</span></label>
        <input type="text" id="pf-title-input" placeholder="e.g., ACT April 2023 – Passage 1">
      </div>
      <div class="field">
        <label class="field-label">Passage Text</label>
        <textarea id="pf-text" rows="7" placeholder="Paste the full passage here. You'll mark individual tested phrases per question below."></textarea>
        <p class="hint">Paste the full paragraph(s). Tested phrases will be highlighted individually for each question.</p>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn-primary" onclick="savePassage()">Save Passage & Add Questions</button>
      <button class="btn-secondary" onclick="closePassageForm()">Cancel</button>
    </div>
  </div>

  <!-- ── Question form (for a passage) ── -->
  <div class="form-card" id="question-form" style="display:none;">
    <h3 id="qf-title">Add Question</h3>
    <div id="qf-passage-context" style="margin-bottom:14px; padding:10px 14px; background:var(--cream); border-left:3px solid var(--rule); font-size:.84rem; color:#5a4e38; font-style:italic; line-height:1.6; max-height:80px; overflow:hidden;"></div>
    <div class="form-fields">
      <div class="field">
        <label class="field-label">Tested Phrase (the underlined portion)</label>
        <input type="text" id="qf-tested" placeholder="Must match passage text exactly — it will be highlighted blue">
      </div>
      <div class="field">
        <label class="field-label">Question Stem <span style="color:#9a8a70;">(optional)</span></label>
        <input type="text" id="qf-stem" placeholder="Which of the following is the best version of the underlined portion?">
      </div>
      <div class="field">
        <label class="field-label">Grammar Category</label>
        <select id="qf-category">
          <option value="Punctuation">Punctuation</option>
          <option value="Subject-Verb Agreement">Subject-Verb Agreement</option>
          <option value="Pronoun Agreement">Pronoun Agreement &amp; Case</option>
          <option value="Verb Tense &amp; Mood">Verb Tense &amp; Mood</option>
          <option value="Redundancy &amp; Wordiness">Redundancy &amp; Wordiness</option>
          <option value="Transitions">Transitions &amp; Logical Flow</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label">Answer Choices</label>
        <div class="choices-block">
          <div class="choice-row"><span class="choice-ltr">A</span><input type="text" id="qc0" placeholder="Choice A"></div>
          <div class="choice-row"><span class="choice-ltr">B</span><input type="text" id="qc1" placeholder="Choice B"></div>
          <div class="choice-row"><span class="choice-ltr">C</span><input type="text" id="qc2" placeholder="Choice C"></div>
          <div class="choice-row"><span class="choice-ltr">D</span><input type="text" id="qc3" placeholder="Choice D (optional)"></div>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Correct Answer</label>
        <div class="correct-row">
          <button class="correct-btn" onclick="selCorrect(0)">A</button>
          <button class="correct-btn" onclick="selCorrect(1)">B</button>
          <button class="correct-btn" onclick="selCorrect(2)">C</button>
          <button class="correct-btn" onclick="selCorrect(3)">D</button>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Explanation</label>
        <textarea id="qf-expl" rows="3" placeholder="Why is this correct? Which rule applies?"></textarea>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn-primary" onclick="saveQuestion()">Save Question</button>
      <button class="btn-secondary" onclick="closeQuestionForm()">Cancel</button>
    </div>
  </div>

  <!-- ── Standalone sentence form ── -->
  <div class="form-card" id="standalone-form" style="display:none;">
    <h3 id="sf-title">Sentence Question</h3>
    <div class="form-fields">
      <div class="field">
        <label class="field-label">Sentence</label>
        <textarea id="sf-sentence" rows="3" placeholder="Type the full sentence here."></textarea>
      </div>
      <div class="field">
        <label class="field-label">Question Stem <span style="color:#9a8a70;">(optional)</span></label>
        <input type="text" id="sf-stem" placeholder="Which of the following is the best version of the underlined portion?">
      </div>
      <div class="field">
        <label class="field-label">Grammar Category</label>
        <select id="sf-category">
          <option value="Punctuation">Punctuation</option>
          <option value="Subject-Verb Agreement">Subject-Verb Agreement</option>
          <option value="Pronoun Agreement">Pronoun Agreement &amp; Case</option>
          <option value="Verb Tense &amp; Mood">Verb Tense &amp; Mood</option>
          <option value="Redundancy &amp; Wordiness">Redundancy &amp; Wordiness</option>
          <option value="Transitions">Transitions &amp; Logical Flow</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label">Answer Choices</label>
        <div class="choices-block">
          <div class="choice-row"><span class="choice-ltr">A</span><input type="text" id="sc0" placeholder="Choice A"></div>
          <div class="choice-row"><span class="choice-ltr">B</span><input type="text" id="sc1" placeholder="Choice B"></div>
          <div class="choice-row"><span class="choice-ltr">C</span><input type="text" id="sc2" placeholder="Choice C"></div>
          <div class="choice-row"><span class="choice-ltr">D</span><input type="text" id="sc3" placeholder="Choice D (optional)"></div>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Correct Answer</label>
        <div class="correct-row">
          <button class="correct-btn" onclick="selSCorrect(0)">A</button>
          <button class="correct-btn" onclick="selSCorrect(1)">B</button>
          <button class="correct-btn" onclick="selSCorrect(2)">C</button>
          <button class="correct-btn" onclick="selSCorrect(3)">D</button>
        </div>
      </div>
      <div class="field">
        <label class="field-label">Explanation</label>
        <textarea id="sf-expl" rows="3" placeholder="Why is this correct? Which rule applies?"></textarea>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn-primary" onclick="saveStandalone()">Save Question</button>
      <button class="btn-secondary" onclick="closeStandaloneForm()">Cancel</button>
    </div>
  </div>
</div>

<!-- ══ STUDENT ══ -->
<div id="student-mode" style="display:none;">
  <div class="no-q" id="no-q-msg" style="display:none;">
    <p>No questions in the bank yet.</p>
    <p style="font-size:.84rem;">Switch to <strong>Tutor</strong> mode to add some first.</p>
  </div>

  <div id="drill-ui" style="display:none;">
    <div class="s-top">
      <span class="score-pill">Score: <strong id="s-score">0 / 0</strong></span>
      <button class="btn-secondary" style="font-size:.76rem;padding:5px 12px;" onclick="resetDrill()">↺ Restart</button>
    </div>
    <div class="cat-filter" id="cat-filter"></div>
    <div class="progress-wrap"><div class="progress-bar" id="s-progress" style="width:0%"></div></div>

    <div class="drill-card" id="drill-card">
